# Server port (default 8787)
PORT=8787

# Client origin allowed by CORS (Vite dev server)
APP_ORIGIN=http://localhost:5173

# 32-byte encryption key for OAuth tokens at rest (hex: 64 chars, or base64)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENC_KEY=

# Secret used to sign session cookies (OAuth CSRF state). Set a strong random
# value in production. Falls back to TOKEN_ENC_KEY if unset.
SESSION_SECRET=

# --- Slack OAuth (https://api.slack.com/apps) ---
# Required scopes: chat:write
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI=http://localhost:8787/api/oauth/slack/callback

# --- Google OAuth (https://console.cloud.google.com/apis/credentials) ---
# Required scopes: drive.file, gmail.send
# Enable Drive API and Gmail API for your project.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8787/api/oauth/google/callback

# --- Notion OAuth (https://www.notion.so/my-integrations) ---
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
NOTION_REDIRECT_URI=http://localhost:8787/api/oauth/notion/callback

# --- Agent runtime (required for scheduled / unattended brief runs) ---
# MUAPI_KEY enables image/video generation tools on the server.
MUAPI_KEY=

# Per-brain LLM keys for cron schedules and Telegram (when enabled).
ANTHROPIC_KEY=
OPENAI_KEY=
GEMINI_KEY=
